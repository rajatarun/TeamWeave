{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LearningMapV1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "current_assessment": {
      "type": "string"
    },
    "target_date": {
      "type": "string"
    },
    "milestones": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "skill_gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "success_rubric": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "current_assessment",
    "target_date",
    "milestones",
    "skill_gaps",
    "success_rubric"
  ]
}