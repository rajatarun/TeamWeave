{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DraftPackV1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "drafts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "variant": {
            "type": "string"
          },
          "post": {
            "type": "string"
          },
          "hashtags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "variant",
          "post",
          "hashtags"
        ]
      }
    }
  },
  "required": [
    "drafts"
  ]
}