{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DraftPackV1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "drafts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "variant": {
            "type": "string"
          },
          "post": {
            "type": "string"
          },
          "linkedin_post": {
            "type": "string"
          },
          "hashtags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "char_count_estimate": {
            "type": "integer"
          },
          "cta_question": {
            "type": "string"
          }
        },
        "required": ["variant", "hashtags"],
        "anyOf": [
          {
            "required": ["post"]
          },
          {
            "required": ["linkedin_post"]
          }
        ]
      }
    }
  },
  "required": [
    "drafts"
  ]
}
